# Copy to key.properties and fill in. key.properties is gitignored.
# See https://docs.flutter.dev/deployment/android#signing-the-app
#
# Passwords are NOT stored in this file. They come from macOS Keychain via
# the RELEASE_STORE_PASSWORD / RELEASE_KEY_PASSWORD env vars set by
# scripts/build-release.sh. See docs/play_store.md for details.
keyAlias=
storeFile=
